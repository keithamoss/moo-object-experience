{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!**/*.css"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"nursery": {
				"noImpliedEval": "error"
			},
			"suspicious": {
				"noArrayIndexKey": "off"
			}
		}
	},
	"javascript": {
		"globals": [
			"afterAll",
			"afterEach",
			"beforeAll",
			"beforeEach",
			"describe",
			"expect",
			"it",
			"test",
			"vi"
		],
		"formatter": {
			"lineWidth": 120,
			"quoteStyle": "single"
		}
	},
	"overrides": [
		{
			"includes": [
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/*.spec.ts",
				"**/*.spec.tsx",
				"**/vitest.setup.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noExplicitAny": "warn"
					},
					"nursery": {
						"noPlaywrightMissingAwait": "error",
						"useExpect": "error"
					}
				}
			}
		}
	]
}
