{
	"name": "moo-object-experience",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "vite --host",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"lint": "tsc --noEmit && biome check --diagnostic-level=error .",
		"lint:fix": "biome check --write --unsafe .",
		"format": "biome format --write .",
		"test": "tsc --noEmit && vitest --run",
		"test:report": "vitest --run; npx vite preview --outDir testing/vitest-report",
		"test:watch": "vitest",
		"test:ui": "vitest --ui --run",
		"test:coverage": "vitest --coverage --run",
		"test:changed": "vitest --run --changed HEAD",
		"test:leak-check": "vitest --run --detect-async-leaks",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:report": "playwright show-report testing/playwright-report",
		"fixtures:update": "npx --yes tsx scripts/capture-fixtures.ts"
	},
	"dependencies": {
		"@gfazioli/mantine-parallax": "^4.0.0",
		"@mantine/colors-generator": "^9.0.0",
		"@mantine/core": "^9.0.0",
		"@mantine/form": "^9.0.0",
		"@mantine/hooks": "^9.0.0",
		"@reduxjs/toolkit": "^2.2.5",
		"@tabler/icons-react": "^3.41.1",
		"@testing-library/dom": "^10.4.1",
		"chroma-js": "^3.2.0",
		"minisearch": "^7.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-redux": "^9.1.2",
		"react-router-dom": "^7.14.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@playwright/test": "^1.59.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-redux": "^7.1.33",
		"@vite-pwa/assets-generator": "^1.0.2",
		"@vitejs/plugin-basic-ssl": "^2.3.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.2",
		"@vitest/ui": "^4.1.2",
		"jsdom": "^29.0.1",
		"msw": "^2.12.14",
		"postcss": "^8.5.8",
		"postcss-preset-mantine": "^1.18.0",
		"postcss-simple-vars": "^7.0.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vite-plugin-checker": "^0.12.0",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.2"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"packageManager": "npm@10.0.0",
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"overrides": {
		"vite-plugin-pwa": {
			"vite": "$vite"
		}
	}
}