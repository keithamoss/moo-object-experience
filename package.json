{
  "name": "moo-object-experience",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit && biome check --diagnostic-level=error .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "test": "tsc --noEmit && vitest --run",
    "test:report": "vitest --run; npx vite preview --outDir testing/vitest-report",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --run",
    "test:coverage": "vitest --coverage --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report testing/playwright-report",
    "fixtures:update": "npx --yes tsx scripts/capture-fixtures.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/system": "^7.3.8",
    "@reduxjs/toolkit": "^2.2.5",
    "@testing-library/dom": "^10.4.1",
    "minisearch": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.33",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "npm@10.0.0",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}